<script>
document.addEventListener("DOMContentLoaded", () => {

    const today = new Date();

    document.getElementById("today").textContent =
    today.toLocaleDateString("id-ID", {
        weekday: "long",
        day: "numeric",
        month: "long",
        year: "numeric"
    });

    function seededRandom(seed){
        let x = Math.sin(seed) * 10000;
        return x - Math.floor(x);
    }

    function getDigit(seed){
        return Math.floor(seededRandom(seed) * 10);
    }

    function generateBBFS(seed){

        const unique = [];
        let i = 0;

        while(unique.length < 6){

            const num = getDigit(seed + i);

            if(!unique.includes(num)){
                unique.push(num);
            }

            i++;
        }

        return unique.join("");
    }

    function getShio(seed){

        const shioList = [
            "TIKUS",
            "KERBAU",
            "MACAN",
            "KELINCI",
            "NAGA",
            "ULAR",
            "KUDA",
            "KAMBING",
            "MONYET",
            "AYAM",
            "ANJING",
            "BABI"
        ];

        return shioList[getDigit(seed) % 12];
    }

    function generateNumbers(){

        const seed =
        today.getFullYear() * 10000 +
        (today.getMonth() + 1) * 100 +
        today.getDate();

        let digits = [];

        for(let i = 0; i < 30; i++){
            digits.push(getDigit(seed + i));
        }

        return {
            angka5 : digits.slice(0,5).join(""),
            bbfs : generateBBFS(seed),
            colokbebas : String(digits[5]),
            d2 : digits.slice(6,8).join(""),
            d3 : digits.slice(8,11).join(""),
            d4 : digits.slice(11,15).join(""),
            macau : digits.slice(15,17).join(""),
            shio : getShio(seed)
        };
    }

    function animateResult(element, finalValue){

        let count = 0;

        const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

        const interval = setInterval(() => {

            let temp = "";

            for(let i = 0; i < finalValue.length; i++){

                if(isNaN(finalValue[i])){
                    temp += chars[
                        Math.floor(Math.random() * chars.length)
                    ];
                }else{
                    temp += Math.floor(Math.random() * 10);
                }
            }

            element.textContent = temp;

            count++;

            if(count >= 25){

                clearInterval(interval);

                element.textContent = finalValue;
            }

        },60);
    }

    function generatePrediction(){

        const btn = document.getElementById("generateBtn");

        btn.disabled = true;
        btn.textContent = "GENERATING...";

        const result = generateNumbers();

        animateResult(
            document.getElementById("angka5"),
            result.angka5
        );

        animateResult(
            document.getElementById("bbfs"),
            result.bbfs
        );

        animateResult(
            document.getElementById("colokbebas"),
            result.colokbebas
        );

        animateResult(
            document.getElementById("d2"),
            result.d2
        );

        animateResult(
            document.getElementById("d3"),
            result.d3
        );

        animateResult(
            document.getElementById("d4"),
            result.d4
        );

        animateResult(
            document.getElementById("macau"),
            result.macau
        );

        animateResult(
            document.getElementById("shio"),
            result.shio
        );

        setTimeout(() => {

            btn.disabled = false;
            btn.textContent = "GENERATE";

        },1700);
    }

    document
        .getElementById("generateBtn")
        .addEventListener("click", generatePrediction);

});
</script>
