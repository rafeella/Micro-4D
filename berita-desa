<script>
document.addEventListener("DOMContentLoaded", function () {

  const reviewContainer = document.getElementById("reviewAuto");

  const schemas = document.querySelectorAll('script[type="application/ld+json"]');

  let reviews = [];

  schemas.forEach(schema => {

    try {

      const json = JSON.parse(schema.textContent);

      // Jika array schema
      if(Array.isArray(json)){

        json.forEach(item => {

          // Review langsung
          if(item["@type"] === "Review"){
            reviews.push(item);
          }

          // Aggregate Product review
          if(item.review){
            if(Array.isArray(item.review)){
              reviews = reviews.concat(item.review);
            } else {
              reviews.push(item.review);
            }
          }

        });

      }

      // Jika object
      else {

        if(json["@type"] === "Review"){
          reviews.push(json);
        }

        if(json.review){

          if(Array.isArray(json.review)){
            reviews = reviews.concat(json.review);
          } else {
            reviews.push(json.review);
          }

        }

      }

    } catch(e){}

  });

  // Ambil hanya 2 review
  reviews.slice(0,2).forEach((review,index) => {

    const author = review.author?.name || "User";
    const text = review.reviewBody || "Review tidak tersedia.";
    const rating = parseInt(review.reviewRating?.ratingValue || 5);
    const date = review.datePublished || "";

    const stars = "★".repeat(rating);

    const initials = author
      .split(" ")
      .map(word => word[0])
      .join("")
      .substring(0,2);

    const card = document.createElement("div");

    card.className = "review-card";

    card.innerHTML = `
      <div class="review-top">

        <div class="review-user">
          <div class="review-avatar">
            ${initials}
          </div>

          <div>
            <div class="review-name">${author}</div>
            <div class="review-date">${date}</div>
          </div>
        </div>

        <div class="review-rating">${stars}</div>

      </div>

      <div class="review-text">
        ${text}
      </div>
    `;

    reviewContainer.appendChild(card);

  });

});
</script>
