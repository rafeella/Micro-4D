    const minutes = String(wib.getMinutes()).padStart(2, "0");
    const seconds = String(wib.getSeconds()).padStart(2, "0");

    document.getElementById("currentDate").textContent =
        `${dayName}, ${day}-${month}-${year} ${hours}.${minutes}.${seconds} WIB`;
}

updateDateTime();
