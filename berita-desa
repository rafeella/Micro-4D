<script>
document.addEventListener("DOMContentLoaded", function () {

  const faqContainer = document.getElementById("faqAuto");

  // Ambil semua schema FAQPage
  const schemas = document.querySelectorAll('script[type="application/ld+json"]');

  let faqData = [];

  schemas.forEach(schema => {
    try {
      const json = JSON.parse(schema.textContent);

      // Jika array
      if(Array.isArray(json)){
        json.forEach(item => {
          if(item["@type"] === "FAQPage"){
            faqData = faqData.concat(item.mainEntity || []);
          }
        });
      }

      // Jika object
      else if(json["@type"] === "FAQPage"){
        faqData = faqData.concat(json.mainEntity || []);
      }

    } catch(e){}
  });

  // Render FAQ otomatis
  faqData.forEach((faq, index) => {

    const question = faq.name || "Pertanyaan";
    const answer = faq.acceptedAnswer?.text || "";

    const item = document.createElement("div");
    item.className = "faq-item";

    item.innerHTML = `
      <button class="faq-question">
        <span>${question}</span>
        <span class="faq-icon">+</span>
      </button>

      <div class="faq-answer">
        <div class="faq-answer-content">
          ${answer}
        </div>
      </div>
    `;

    faqContainer.appendChild(item);
  });

  // Accordion
  document.querySelectorAll(".faq-question").forEach(btn => {
    btn.addEventListener("click", function(){

      const item = this.parentElement;

      item.classList.toggle("active");

    });
  });

});
</script>

